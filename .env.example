# ─────────────────────────────────────────────────────
# FDD Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# OpenAI API Key
# Get one at: https://platform.openai.com/api-keys
# Leave blank to use mock LLM mode (USE_MOCK_LLM=true)
OPENAI_API_KEY=

# OpenAI model — gpt-4o-mini is cheapest for testing, gpt-4o for production quality
OPENAI_MODEL=gpt-4o-mini

# LLM Mode
# true  → all LLM agents return fixture responses (no API key needed)
# false → real Claude API calls (requires ANTHROPIC_API_KEY above)
USE_MOCK_LLM=false

# Storage directories (relative to where uvicorn is launched, i.e. backend/)
DEAL_STORE_DIR=data/deals
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed

# CORS — add your frontend URL here
# Default covers both Vite (5173) and CRA (3000) dev servers
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
